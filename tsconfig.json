{
  "compilerOptions": {
    "target": "ES2021",
    "lib": [
      "ES2021"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@/jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./build/*"]
    }
  },
  "include": [
    "build",
    "content"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
